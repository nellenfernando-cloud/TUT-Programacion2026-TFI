// armamos el proc3so que necesitamos
Proceso AreaTriangulo
    Definir base, altura, área Como Real
	
	
	// ingresamos los datos a ejecutar en la ecuación
    Escribir "Ingrese la base:"
    Leer base
	
    Escribir "Ingrese la altura:"
    Leer altura
	
    area <- (base * altura) / 2
	
	
	// lo imprimimos
    Escribir "Área: ", area
FinProceso

	